# Upstash Redis (replaces deprecated Vercel KV)
# Get these from Vercel Storage dashboard → Add Store → Upstash Redis
# Or directly from upstash.com → Create Database → REST API tab
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Groq — used for AI portfolio analysis and the Investment Advisor chatbot (Llama 3.3 70B)
# Free tier: no credit card required — sign up at console.groq.com → API Keys
GROQ_API_KEY=

# Google Gemini — alternative AI provider for analysis and chatbot (Gemini 2.5 Flash)
# Free tier available — get a key at aistudio.google.com
GEMINI_API_KEY=

# Optional: password gate for the dashboard (casual protection only — baked into the JS bundle)
# Omit or leave blank to disable the password gate entirely
NEXT_PUBLIC_DASHBOARD_PASSWORD=
